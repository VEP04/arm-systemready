+          - "EFI_VARIABLE_RUNTIME_ACCESS"
+          - "EXPECTED_ATTR_CAPSULE_MAX"
+          - "EXPECTED_ATTR_CAPSULE_LAST"
+          - "EXPECTED_ATTR_CAPSULE_NNNN"
+
+      - name: contains_guid_constants
+        type: source_contains_all
+        patterns:
+          - "CapsuleReportGuid"
+          - "GlobalVariableGuid"
+          - "EFI_OS_INDICATIONS_FILE_CAPSULE_DELIVERY_SUPPORTED"
+
+      - name: contains_path_and_regex_constants
+        type: source_contains_all
