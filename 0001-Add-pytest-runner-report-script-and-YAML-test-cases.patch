+                p = str(self)
+                if p.endswith("/sys/class/net/eth0/carrier"):
+                    return "1"
+                if p.endswith("/sys/class/net/eth1/carrier"):
+                    return "0"
+                if p.endswith("/sys/class/net/eth0/operstate"):
+                    return "up"
+                if p.endswith("/sys/class/net/eth1/operstate"):
+                    return "down"
+                return ""
+
+            subprocess.check_output = fake_check_output
+            subprocess.run = fake_run
+            subprocess.call = fake_call
+            subprocess.check_call = fake_check_call
+            subprocess.Popen = FakePopen
+            shutil.which = fake_which
+            Path.resolve = fake_resolve
+            Path.read_text = fake_read_text
+
+            sys.argv = [target, cfg]
+            runpy.run_path(target, run_name="__main__")
+            PY
+        args:
+          - "{file}"
+        expect_stdout_or_stderr_contains:
+          - "eth0"
+          - "eth1"
