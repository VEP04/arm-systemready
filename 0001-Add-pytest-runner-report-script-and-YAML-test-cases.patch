+        function: "_ensure_log_dir"
+
+      - name: contains_log_function
+        type: function_exists
+        function: "log"
+
+      - name: contains_status_function
+        type: function_exists
+        function: "status"
+
+      - name: contains_read_efi_var_function
+        type: function_exists
+        function: "read_efi_var"
+
+      - name: contains_decode_char16_function
+        type: function_exists
+        function: "decode_char16_11_no_nul"
+
+      - name: contains_os_indications_supports_ondisk_function
