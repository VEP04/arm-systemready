+
+      - name: contains_os_indications_supported_name
+        type: source_contains
+        pattern: "OsIndicationsSupported"
+
+      - name: contains_capsule_variable_names
+        type: source_contains_all
+        patterns:
+          - "CapsuleMax"
+          - "CapsuleLast"
+          - "CapsuleNNNN"
+
+      - name: contains_sorting_or_iteration_for_capsules
+        type: source_contains_any
+        patterns:
+          - "sorted("
+          - "for name in"
+          - "for var_name in"
+
+      - name: contains_log_messages
+        type: source_contains_any
+        patterns:
+          - "Capsule On-Disk Update Reporting"
+          - "CapsuleMax"
+          - "CapsuleLast"
+
+      - name: contains_exception_handling
+        type: source_contains_any
+        patterns:
+          - "except (OSError, IOError):"
+          - "except OSError:"
+          - "except IOError:"
+
+      - name: contains_functions_primary
+        type: function_exists_any
+        functions:
+          - "_ensure_log_dir"
+          - "log"
+          - "status"
+          - "read_efi_var"
+          - "decode_char16_11_no_nul"
+          - "os_indications_supports_ondisk"
+          - "log_attr_test"
+          - "check_capsulemax"
+          - "check_capsulelast"
+          - "check_capsule_nnnn"
+          - "main"
