+          - "_ensure_log_dir()"
+
+      - name: contains_file_open_append_logic
+        type: source_contains_all
+        patterns:
+          - "with open(LOG_FILE, \"a\", encoding=\"utf-8\") as f:"
+          - "f.write(msg + \"\\n\")"
